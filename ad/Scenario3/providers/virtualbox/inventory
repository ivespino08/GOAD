router-3     ansible_host=192.168.57.13 ansible_ssh_private_key_file=.vagrant/machines/router-3/virtualbox/private_key
router-4     ansible_host=192.168.57.14 ansible_ssh_private_key_file=.vagrant/machines/router-4/virtualbox/private_key
router-5     ansible_host=192.168.57.15 ansible_ssh_private_key_file=.vagrant/machines/router-5/virtualbox/private_key
pc-1         ansible_host=192.168.57.21 ansible_ssh_private_key_file=.vagrant/machines/pc-1/virtualbox/private_key
pc-3         ansible_host=192.168.57.23 ansible_ssh_private_key_file=.vagrant/machines/pc-3/virtualbox/private_key
pc-4         ansible_host=192.168.57.24 ansible_ssh_private_key_file=.vagrant/machines/pc-4/virtualbox/private_key
