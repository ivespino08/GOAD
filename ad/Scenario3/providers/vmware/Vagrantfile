# ad/Scenario3/providers/vmware/Vagrantfile
#
# The GOAD framework substitutes this file's content at the {{lab}}
# placeholder inside template/provider/vmware/Vagrantfile, placing it
# inside the template's existing Vagrant.configure block.
#
# :networks adds extra private_network adapters AFTER the management
# adapter (eth1). The template's boxes.each loop reads :networks and
# creates them in order, so:
#   eth0 = NAT (automatic)
#   eth1 = :ip (management, 192.168.57.x)
#   eth2 = :networks[0] (first r2r link, peer_idx 0)
#   eth3 = :networks[1] (second r2r link, peer_idx 1)
#
# :networks order MUST match r2r_interfaces key order in config.json
# because topology-routers.yml uses peer_idx+2 for interface naming.

