; Inventory — Provider Inventory (VMware)
; ad/Scenario3/providers/vmware/inventory
;
; {{ip_range}} is substituted by Utils.replace_in_file() in the GOAD
; framework before Ansible runs. Value comes from ip_range in ~/.goad/goad.ini.
;
; All lab VMs share the Vagrant insecure private key because the Vagrantfile
; sets config.ssh.insert_key = false for all non-PROVISIONING VMs.
; setup_local_jumpbox.sh installs the key at ~/.vagrant.d/insecure_private_key.
;
; PROVISIONING uses its own generated key (not listed here — the framework
; resolves it via local_jumpbox.py get_jumpbox_key() directly).

[default]
router-1   ansible_host={{ip_range}}.11  dict_key=router-1   ansible_ssh_private_key_file=~/.vagrant.d/insecure_private_key
router-2   ansible_host={{ip_range}}.12  dict_key=router-2   ansible_ssh_private_key_file=~/.vagrant.d/insecure_private_key
router-3   ansible_host={{ip_range}}.13  dict_key=router-3   ansible_ssh_private_key_file=~/.vagrant.d/insecure_private_key
router-4   ansible_host={{ip_range}}.14  dict_key=router-4   ansible_ssh_private_key_file=~/.vagrant.d/insecure_private_key
router-5   ansible_host={{ip_range}}.15  dict_key=router-5   ansible_ssh_private_key_file=~/.vagrant.d/insecure_private_key
pc-1       ansible_host={{ip_range}}.21  dict_key=pc-1       ansible_ssh_private_key_file=~/.vagrant.d/insecure_private_key
pc-3       ansible_host={{ip_range}}.23  dict_key=pc-3       ansible_ssh_private_key_file=~/.vagrant.d/insecure_private_key
pc-4       ansible_host={{ip_range}}.24  dict_key=pc-4       ansible_ssh_private_key_file=~/.vagrant.d/insecure_private_key
pc-5       ansible_host={{ip_range}}.25  dict_key=pc-5       ansible_ssh_private_key_file=~/.vagrant.d/insecure_private_key
pc-8       ansible_host={{ip_range}}.28  dict_key=pc-8       ansible_ssh_private_key_file=~/.vagrant.d/insecure_private_key
docker-11  ansible_host={{ip_range}}.31  dict_key=docker-11  ansible_ssh_private_key_file=~/.vagrant.d/insecure_private_key
docker-12  ansible_host={{ip_range}}.32  dict_key=docker-12  ansible_ssh_private_key_file=~/.vagrant.d/insecure_private_key

