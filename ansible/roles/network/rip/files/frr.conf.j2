! frr.conf.j2 — FRR RIP configuration
! Rendered by roles/network/rip/tasks/main.yml
!
! eth0 (NAT) and eth1 (management) are passive — RIP only runs on
! eth2/eth3 (physical r2r adapters). This ensures each router only
! learns routes from its immediate neighbours, enforcing the multi-hop chain.
frr version 8.1
frr defaults traditional
log syslog informational
!
router rip
 version 2
{% for network in rip_networks %}
 network {{network}}
{% endfor %}
{% for iface in rip_passive_interfaces %}
 passive-interface {{iface}}
{% endfor %}
!
line vty
!
