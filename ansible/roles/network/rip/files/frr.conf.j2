! frr.conf.j2 — generated by Ansible for {{hostname | default(inventory_hostname)}}
frr version 8.5
frr defaults traditional
hostname {{hostname | default(inventory_hostname)}}
log syslog informational
no ipv6 forwarding
!
router rip
 version 2
{% for network in rip_networks %}
 network {{network}}
{% endfor %}
{% for iface in rip_passive_interfaces | default([]) %}
 passive-interface {{iface}}
{% endfor %}
 redistribute connected
!
line vty
!
