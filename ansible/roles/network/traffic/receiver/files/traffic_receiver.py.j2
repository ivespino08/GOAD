#!/usr/bin/env python3
# traffic_receiver.py.j2 — generated by Ansible
# Listens for {{protocol}} background traffic on {{bind_ip4}}:9000

import socket
import time

BIND_IP   = "{{bind_ip4}}"
BIND_PORT = 9000
CHUNK     = 1024

def receive():
    while True:
        try:
{% if protocol == "TCP" %}
            with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
                s.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
                s.bind((BIND_IP, BIND_PORT))
                s.listen(5)
                conn, addr = s.accept()
                with conn:
                    while True:
                        data = conn.recv(CHUNK)
                        if not data:
                            break
{% elif protocol == "UDP" %}
            with socket.socket(socket.AF_INET, socket.SOCK_DGRAM) as s:
                s.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
                s.bind((BIND_IP, BIND_PORT))
                while True:
                    data, addr = s.recvfrom(CHUNK)
{% endif %}
        except Exception as e:
            time.sleep(2)

if __name__ == "__main__":
    receive()
