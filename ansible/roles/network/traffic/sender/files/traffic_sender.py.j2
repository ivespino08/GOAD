# Sends {{protocol}} background traffic from {{src_ip4}} to {{dst_ip4}}
# Rate: {{rate_kbps}} kbps | Pattern: {{pattern}}

import socket
import time
import sys

DST_IP   = "{{dst_ip4}}"
DST_PORT = 9000
RATE_BPS = {{rate_kbps}} * 1024
CHUNK    = 1024  # bytes per send

def send():
    interval = CHUNK / RATE_BPS
    while True:
        try:
{% if protocol == "TCP" %}
            with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
                s.settimeout(5)
                s.connect((DST_IP, DST_PORT))
                while True:
                    s.sendall(b"X" * CHUNK)
                    time.sleep(interval)
{% elif protocol == "UDP" %}
            with socket.socket(socket.AF_INET, socket.SOCK_DGRAM) as s:
                while True:
                    s.sendto(b"X" * CHUNK, (DST_IP, DST_PORT))
                    time.sleep(interval)
{% endif %}
        except Exception as e:
            time.sleep(2)

if __name__ == "__main__":
    send()
