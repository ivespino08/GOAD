Vagrant.configure("2") do |config|

ENV['VAGRANT_DEFAULT_PROVIDER'] = 'vmware_desktop'

{{lab}}

{{extensions}}

{% if use_provisioning_vm %}
boxes.unshift(
    { :name => "PROVISIONING",
      :ip => "{{ip_range}}.3",
      :box => "bento/ubuntu-22.04",
      :box_version => "202401.31.0",
      :os => "linux",
      :cpus => 2,
      :mem => 2000
    }
)
{% endif %}

  config.vm.provider "vmware_desktop" do |v|
    v.force_vmware_license = "workstation"  # force the licence for fix some vagrant plugin issue
    # v.gui = true
  end

  # disable rdp forwarded port inherited from StefanScherer box
  config.vm.network :forwarded_port, guest: 3389, host: 3389, id: "rdp", auto_correct: true, disabled: true

  # no autoupdate if vagrant-vbguest is installed
  if Vagrant.has_plugin?("vagrant-vbguest") then
    config.vbguest.auto_update = false
  end

  config.vm.boot_timeout = 600
  config.vm.graceful_halt_timeout = 600
  config.winrm.retry_limit = 30
  config.winrm.retry_delay = 10

  boxes.each do |box|
    config.vm.define box[:name] do |target|
      # BOX
      target.vm.provider "vmware_desktop" do |v|
        v.vmx["memsize"] = box[:mem]
        v.vmx["numvcpus"] = box[:cpus]
      end

      target.vm.box_download_insecure = box[:box]
      target.vm.box = box[:box]
      if box.has_key?(:box_version)
        target.vm.box_version = box[:box_version]
      end

      # issues/49
      target.vm.synced_folder '.', '/vagrant', disabled: true

      # Management IP (eth1 — slot 2, after NAT on eth0)
      target.vm.network :private_network, ip: box[:ip]

      # Additional networks for r2r links (eth2, eth3, ... — slots 3+)
      # Add :networks => ["ip1", "ip2"] to a box hash to create extra adapters.
      # Adapters appear in order: eth2 = networks[0], eth3 = networks[1], etc.
      if box.has_key?(:networks)
        box[:networks].each do |net_ip|
          target.vm.network :private_network, ip: net_ip
        end
      end

      # Bridged adapter for hardware-in-the-loop (HITL) participant networks.
      # Unlike :networks above (all private_network / virtual-only), this
      # bridges the VM to a real physical NIC on the host, so it can reach
      # actual external hardware (e.g. router-3's ens19 in Scenario3).
      # Add :bridge_adapter => "<host NIC name>" to a box hash to enable it.
      #
      # IMPORTANT: the resulting guest interface name is NOT guaranteed to
      # match whatever slug you've picked in config.json (e.g. "ens19") —
      # it depends on predictable-network-interface-naming and PCI bus
      # ordering on the specific host/hypervisor. After `vagrant reload`,
      # SSH in and confirm with `ip link show` before trusting the name
      # baked into config.json; update config.json rather than the role
      # if they don't match.
      if box.has_key?(:bridge_adapter)
        target.vm.network "public_network", bridge: box[:bridge_adapter]
      end

      # OS specific
      if box[:os] == "windows"
        target.vm.guest = :windows
        target.vm.communicator = "winrm"
        target.vm.provision :shell, :path => "../../../vagrant/Install-WMF3Hotfix.ps1", privileged: false
        target.vm.provision :shell, :path => "../../../vagrant/ConfigureRemotingForAnsible.ps1", privileged: false

        # fix ip for vmware
        if ENV['VAGRANT_DEFAULT_PROVIDER'] == "vmware_desktop"
          target.vm.provision :shell, :path => "../../../vagrant/fix_ip.ps1", privileged: false, args: box[:ip]
        end
      else
        target.vm.communicator = "ssh"
      end

      if box.has_key?(:forwarded_port)
        # forwarded port explicit
        box[:forwarded_port].each do |forwarded_port|
          target.vm.network :forwarded_port, guest: forwarded_port[:guest], host: forwarded_port[:host], host_ip: "127.0.0.1", id: forwarded_port[:id]
        end
      end

    end
  end
end
